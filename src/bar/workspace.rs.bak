use std::cell::RefCell;
use std::rc::Rc;

use gtk::prelude::*;
use gtk::gdk;

use crate::hyprland::{self, EventBus, Subscription};

pub struct WorkspaceWidget {
    pub container: gtk::Box,
    labels: Rc<RefCell<Vec<gtk::Label>>>,
    bound: Rc<RefCell<Vec<String>>>,
    active_name: Rc<RefCell<Option<String>>>,
    _subs: Vec<Subscription>,
}

impl WorkspaceWidget {
    pub fn new(monitor: &gdk::Monitor, event_bus: &EventBus) -> Self {
        let connector = monitor
            .connector()
            .unwrap_or_default()
            .to_string();

        let bound = Rc::new(RefCell::new(bound_for(&connector)));
        let active_name = Rc::new(RefCell::new(
            hyprland::get_active_workspace().map(|w| w.name),
        ));

        let container = gtk::Box::new(gtk::Orientation::Horizontal, 2);
        let labels = Rc::new(RefCell::new(build_labels(
            &container,
            &bound.borrow(),
            &active_name.borrow(),
        )));

        // ── event subscriptions ───────────────────────────────────
        let mut subs = Vec::new();

        // shared update helper: re-query activeworkspace and refresh
        let update_highlight = {
            let bound = bound.clone();
            let active_name = active_name.clone();
            let labels = labels.clone();
            move || {
                let name = hyprland::get_active_workspace().map(|w| w.name);
                eprintln!("[workspace] refresh: active={:?}", name);
                *active_name.borrow_mut() = name;
                refresh_highlight(&labels.borrow(), &bound.borrow(), &active_name.borrow());
            }
        };

        // workspacev2 >> ID,WINDOWCOUNT,MONITORNAME
        {
            let connector = connector.clone();
            let update = update_highlight.clone();
            subs.push(event_bus.subscribe("workspacev2", move |data| {
                let mon = data.split(',').nth(2).unwrap_or("");
                if mon == connector {
                    update();
                }
            }));
        }

        // focusedmonv2 >> MONITORID,MONITORNAME,WORKSPACEID,WORKSPACENAME
        {
            let connector = connector.clone();
            let update = update_highlight.clone();
            subs.push(event_bus.subscribe("focusedmonv2", move |data| {
                let parts: Vec<&str> = data.split(',').collect();
                if parts.len() >= 2 && parts[1] == connector {
                    update();
                }
            }));
        }

        // monitoraddedv2 / monitorremovedv2 — rebind
        {
            let bound = bound.clone();
            let active_name = active_name.clone();
            let labels = labels.clone();
            let container = container.clone();
            let connector = connector.clone();
            let rebind = move || {
                let new_bound = bound_for(&connector);
                *bound.borrow_mut() = new_bound;
                let mut labels_mut = labels.borrow_mut();
                // clear container
                while let Some(child) = container.first_child() {
                    container.remove(&child);
                }
                // rebuild
                *labels_mut = build_labels(
                    &container,
                    &bound.borrow(),
                    &active_name.borrow(),
                );
            };
            subs.push(event_bus.subscribe("monitoraddedv2", {
                let rebind = rebind.clone();
                move |_| rebind()
            }));
            subs.push(event_bus.subscribe("monitorremovedv2", move |_| rebind()));
        }

        WorkspaceWidget {
            container,
            labels,
            bound,
            active_name,
            _subs: subs,
        }
    }
}

// ── helpers ──────────────────────────────────────────────────────

fn bound_for(connector: &str) -> Vec<String> {
    eprintln!("hyprland workspace rules: {:?}", hyprland::get_workspace_rules());
    let mut rules: Vec<_> = hyprland::get_workspace_rules()
        .into_iter()
        // .filter(|r| r.monitor == connector)
        .collect();
    rules.sort_by(|a, b| {
        let na: i64 = a.workspace_string.parse().unwrap_or(i64::MAX);
        let nb: i64 = b.workspace_string.parse().unwrap_or(i64::MAX);
        na.cmp(&nb).then_with(|| a.workspace_string.cmp(&b.workspace_string))
    });
    let names: Vec<String> = rules.into_iter().map(|r| r.workspace_string).collect();
    eprintln!(
        "[workspace] bound for {:?}: {:?}",
        connector, names
    );
    names
}

fn build_labels(
    container: &gtk::Box,
    bound: &[String],
    active_name: &Option<String>,
) -> Vec<gtk::Label> {
    bound
        .iter()
        .map(|name| {
            let label = gtk::Label::new(Some(name));
            label.add_css_class("workspace-label");

            if active_name.as_ref() == Some(name) {
                label.add_css_class("workspace-active");
            }

            // click
            let target = name.clone();
            let gesture = gtk::GestureClick::new();
            gesture.connect_pressed(move |_gesture, _n, _x, _y| {
                eprintln!("[workspace] dispatch to {}", target);
                hyprland::dispatch_workspace(&target);
            });
            label.add_controller(gesture);

            // scroll
            let bound_scroll: Vec<String> = bound.to_vec();
            let active_scroll: Option<String> = active_name.clone();
            let scroll = gtk::EventControllerScroll::new(
                gtk::EventControllerScrollFlags::VERTICAL,
            );
            scroll.connect_scroll(move |_ctrl, _dx, dy| {
                let n = bound_scroll.len();
                if n == 0 {
                    return gtk::glib::Propagation::Proceed;
                }
                let cur = bound_scroll
                    .iter()
                    .position(|n| Some(n) == active_scroll.as_ref())
                    .unwrap_or(0);
                let new = if dy > 0.0 {
                    (cur + 1) % n
                } else {
                    (cur + n - 1) % n
                };
                eprintln!("[workspace] scroll to {}", bound_scroll[new]);
                hyprland::dispatch_workspace(&bound_scroll[new]);
                gtk::glib::Propagation::Proceed
            });
            label.add_controller(scroll);

            container.append(&label);
            label
        })
        .collect()
}

fn refresh_highlight(labels: &[gtk::Label], bound: &[String], active_name: &Option<String>) {
    // clear all first
    for label in labels {
        label.remove_css_class("workspace-active");
    }
    // set the active one
    if let Some(name) = active_name {
        if let Some(pos) = bound.iter().position(|n| n == name) {
            if let Some(label) = labels.get(pos) {
                label.add_css_class("workspace-active");
            }
        }
    }
}
